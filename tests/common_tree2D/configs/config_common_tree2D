simulation_parameters
{
    // These files are used by common_tree.cpp/common_tree_Test.cpp
    // Update paths to snapshots generated by your run.
    nStart=100;
    nTotal=3;
    nskip=100;

    nLevels=0;
    refinement_factor=0.125;

    output
    {
        // Driver builds snapshot paths as:
        //   ./<field_dir>/flowTime_<idx>.hdf5
        //   ./<field_dir>/tree_info_<idx>.bin
        directory=output;
        field_dir=output;
    }

    // Present for compatibility with other drivers/tests.
    tree_ref_file=./output/tree_info_100.bin;
    flow_ref_file=./output/flowTime_100.hdf5;

    domain
    {
        // 2D setup
        bd_base = (-128,-128);
        bd_extent = (256,256);

        Lx=20.0;
        dx_base=0.25;
        block_extent=8;

        block
        {
            base=(-128,-128);
            extent=(256,256);
        }
    }
}
